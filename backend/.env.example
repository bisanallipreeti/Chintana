APP_NAME=chintana-backend
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
TRUST_PROXY=true
FORCE_HTTPS=false

MONGODB_URI=mongodb://127.0.0.1:27017/chintana

ACCESS_TOKEN_SECRET=replace-with-strong-access-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_SECRET=replace-with-strong-refresh-secret
REFRESH_TOKEN_TTL_DAYS=30
OTP_TTL_MINUTES=10
PASSWORD_RESET_TTL_MINUTES=20
BCRYPT_SALT_ROUNDS=12

CORS_ORIGINS=http://localhost:5173,http://localhost:8081,exp://127.0.0.1:19000,https://*.vercel.app
CLIENT_APP_URL=http://localhost:5173
PASSWORD_RESET_URL=http://localhost:5173/reset-password
MOBILE_SCHEME=chintana

GROQ_API_BASE_URL=https://api.groq.com/openai/v1
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODELS=llama-3.1-8b-instant
GROQ_MAX_TOKENS=420
GROQ_TEMPERATURE=0.2
GROQ_TLS_REJECT_UNAUTHORIZED=true
AI_TIMEOUT_MS=22000
AI_MAX_RETRIES=0
AI_RETRY_BASE_DELAY_MS=600
AI_CACHE_TTL_SECONDS=900
AI_CACHE_MAX_ENTRIES=5000
AI_DAILY_LIMIT_PER_USER=120

ENABLE_BULLMQ=false
REDIS_URL=
DAILY_REMINDER_SWEEP_INTERVAL_MINUTES=60
INTERNAL_CRON_KEY=replace-with-internal-cron-key

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
MAIL_FROM=Chintana <your-email@gmail.com>

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=chintana

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
LOG_LEVEL=info
API_DOCS_ENABLED=true
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_IDS=

